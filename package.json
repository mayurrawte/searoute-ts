{
  "name": "searoute-ts",
  "version": "2.0.0",
  "description": "Shortest sea route between any two points on Earth. TypeScript library with the Eurostat 2025 maritime network, canal/strait restrictions (Suez, Panama, Bab-el-Mandeb…), vessel-draft gating, K-shortest alternatives, multi-leg waypoints, and ETA from vessel speed. Dual ESM/CJS, zero peer deps.",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mayurrawte/searoute-ts.git"
  },
  "license": "MIT",
  "author": "Mayur Rawte",
  "keywords": [
    "searoute",
    "sea-route",
    "sea-routes",
    "marine-route",
    "ocean-route",
    "maritime-route",
    "shipping-route",
    "shipping-lanes",
    "ship-routing",
    "vessel-routing",
    "voyage-planning",
    "port-to-port",
    "great-circle",
    "nautical-miles",
    "shortest-path",
    "dijkstra",
    "geojson",
    "maritime",
    "shipping",
    "logistics",
    "supply-chain",
    "ocean-shipping",
    "container-shipping",
    "suez",
    "panama-canal",
    "cape-of-good-hope",
    "eurostat",
    "marnet",
    "typescript"
  ],
  "scripts": {
    "clean": "rm -rf dist build coverage",
    "build": "npm run clean && npm run build:cjs && npm run build:esm && npm run build:types && node scripts/fixup-cjs.cjs",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:types": "tsc -p tsconfig.types.json",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.{ts,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,json}\"",
    "test": "npm run build:test && ava",
    "test:unit": "ava",
    "build:test": "tsc -p tsconfig.test.json",
    "prepublishOnly": "npm run lint && npm run test"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@turf/distance": "^7.3.0",
    "@turf/helpers": "^7.3.0",
    "@turf/length": "^7.3.0",
    "@turf/meta": "^7.3.0",
    "@turf/point-to-line-distance": "^7.3.0",
    "geojson-path-finder": "^2.1.0"
  },
  "devDependencies": {
    "@ava/typescript": "^6.0.0",
    "@types/geojson": "^7946.0.14",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "ava": "^6.2.0",
    "eslint": "^9.16.0",
    "prettier": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "ava": {
    "typescript": {
      "rewritePaths": {
        "src/": "build/test/"
      },
      "compile": false
    },
    "files": [
      "src/**/*.spec.ts"
    ],
    "timeout": "60s"
  },
  "prettier": {
    "singleQuote": true,
    "printWidth": 100,
    "trailingComma": "all"
  },
  "bugs": {
    "url": "https://github.com/mayurrawte/searoute-ts/issues"
  },
  "homepage": "https://github.com/mayurrawte/searoute-ts#readme"
}
