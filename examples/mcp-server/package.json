{
  "name": "@searoute-ts/mcp",
  "version": "0.1.0",
  "description": "Model Context Protocol server exposing searoute-ts sea-route tools (sea_route, sea_route_alternatives) to AI agents.",
  "type": "module",
  "bin": {
    "searoute-ts-mcp": "dist/index.js"
  },
  "main": "dist/server.js",
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "searoute",
    "sea-route",
    "maritime",
    "shipping",
    "ai-agents",
    "claude"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "searoute-ts": "^2.2.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.9"
  }
}
